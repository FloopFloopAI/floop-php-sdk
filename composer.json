{
    "name": "floopfloop/sdk",
    "description": "Official PHP SDK for the FloopFloop API — build, refine, and manage FloopFloop projects from any PHP codebase.",
    "type": "library",
    "keywords": ["floopfloop", "sdk", "vibe-coding", "api-client"],
    "homepage": "https://www.floopfloop.com",
    "license": "MIT",
    "authors": [
        {
            "name": "FloopFloop",
            "email": "info@floopfloop.com",
            "homepage": "https://www.floopfloop.com"
        }
    ],
    "support": {
        "source": "https://github.com/FloopFloopAI/floop-php-sdk",
        "issues": "https://github.com/FloopFloopAI/floop-php-sdk/issues"
    },
    "require": {
        "php": ">=8.1",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "FloopFloop\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FloopFloop\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "alpha",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
